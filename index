// ── ESTADO ─────────────────────────────────────────────────────────────────
var S = {
  tipo: null,
  items: [],        // [{nombre, cantidad, unidad, motivo}]
  prodSeleccionado: null,
  motivoActual: null
};

// ── HORA ───────────────────────────────────────────────────────────────────
function tick() {
  var d = new Date();
  document.getElementById('hora').textContent =
    d.toLocaleDateString('es-AR',{weekday:'short',day:'numeric',month:'short'}) +
    ' · ' + d.toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'});
}
tick(); setInterval(tick, 30000);

// ── PASO 1: TIPO ───────────────────────────────────────────────────────────
function selTipo(tipo) {
  S.tipo = tipo;
  S.items = [];
  S.prodSeleccionado = null;
  S.motivoActual = null;

  ['consumo','traslado','merma','pt'].forEach(function(t) {
    document.getElementById('t-'+t).className = 'tipo-btn';
  });
  document.getElementById('t-'+tipo).className = 'tipo-btn sel-'+tipo;

  var titulos = {
    consumo: '¿Qué productos se consumieron?',
    traslado: '¿Qué productos se trasladan?',
    merma: '¿Qué productos se perdieron?',
    pt: '¿Qué productos terminados?'
  };
  document.getElementById('ttl-productos').textContent = titulos[tipo];

  document.getElementById('card-productos').classList.remove('hidden');
  document.getElementById('card-obs').classList.remove('hidden');
  document.getElementById('items-wrap').classList.add('hidden');
  document.getElementById('items-list').innerHTML = '';
  document.getElementById('add-form').classList.remove('show');
  document.getElementById('search-inp').value = '';

  renderLista('');
  actualizarBoton();

  setTimeout(function() {
    document.getElementById('card-productos').scrollIntoView({behavior:'smooth',block:'nearest'});
  }, 100);
}

// ── LISTA DE PRODUCTOS ──────────────────────────────────────────────────────
function renderLista(filtro) {
  var lista = document.getElementById('prod-list');
  var f = filtro.toLowerCase();
  var html = '';
  var fuente = S.tipo === 'pt' ? null : MP;

  if (S.tipo === 'pt') {
    PT.forEach(function(p, i) {
      if (!f || p.toLowerCase().includes(f)) {
        html += '<button type="button" class="prod-btn" data-ptidx="'+i+'"><span>'+p+'</span></button>';
      }
    });
  } else {
    Object.keys(fuente).forEach(function(cat) {
      var prods = fuente[cat].filter(function(p) {
        var nombre = typeof p === 'object' ? p.n : p;
        return !f || nombre.toLowerCase().includes(f);
      });
      if (!prods.length) return;
      if (!f) html += '<div class="cat-lbl">'+cat+'</div>';
      prods.forEach(function(p) {
        var nombre = typeof p === 'object' ? p.n : p;
        var unidad = typeof p === 'object' ? p.u : 'unid.';
        var safe = nombre.replace(/&/g,'&amp;').replace(/"/g,'&quot;');
        var safeU = unidad.replace(/&/g,'&amp;').replace(/"/g,'&quot;');
        html += '<button type="button" class="prod-btn" data-nombre="'+safe+'" data-unidad="'+safeU+'"><span>'+nombre+'</span></button>';
      });
    });
  }

  lista.innerHTML = html || '<div style="font-size:12px;color:var(--mut);padding:10px;text-align:center">Sin resultados</div>';

  lista.onclick = function(e) {
    var btn = e.target.closest('.prod-btn');
    if (!btn) return;
    var nombre = btn.getAttribute('data-nombre');
    var unidad = btn.getAttribute('data-unidad') || 'unid.';
    var ptidx  = btn.getAttribute('data-ptidx');
    if (ptidx !== null) {
      abrirAddForm(PT[parseInt(ptidx)], 'unid.');
    } else {
      abrirAddForm(nombre, unidad);
    }
  };
}

function filtrar(q) { renderLista(q); }

// ── MINI FORM: AGREGAR PRODUCTO ─────────────────────────────────────────────
function abrirAddForm(nombre, unidadPredeterminada) {
  S.prodSeleccionado = nombre;
  S.motivoActual = null;

  document.getElementById('add-nombre').textContent = nombre;
  var cantInp = document.getElementById('cant-inp');
  cantInp.value = '';
  document.getElementById('btn-agregar').disabled = true;

  // Pre-seleccionar la unidad del producto
  if (unidadPredeterminada) {
    var uniSel = document.getElementById('uni-sel');
    var opciones = uniSel.options;
    var encontrada = false;
    for (var i = 0; i < opciones.length; i++) {
      if (opciones[i].value === unidadPredeterminada ||
          opciones[i].value.toLowerCase() === unidadPredeterminada.toLowerCase()) {
        uniSel.selectedIndex = i;
        encontrada = true;
        break;
      }
    }
    // Si no está en la lista, usar 'unid.' por defecto
    if (!encontrada) uniSel.value = 'unid.';
  }

  // Re-registrar listener
  cantInp.oninput = function() {
    var val = parseFloat(this.value);
    var necesitaMotivo = S.tipo === 'merma' || S.tipo === 'pt';
    var motivoOk = !necesitaMotivo || S.motivoActual;
    document.getElementById('btn-agregar').disabled = !(val > 0 && motivoOk);
  };

  // Resetear motivos
  ['venc','prep','acc','otro'].forEach(function(m) {
    document.getElementById('m-'+m).className = 'mot-btn';
  });

  // Mostrar/ocultar motivo
  var necesitaMotivo = S.tipo === 'merma' || S.tipo === 'pt';
  document.getElementById('motivo-wrap').classList.toggle('hidden', !necesitaMotivo);

  document.getElementById('add-form').classList.add('show');

  setTimeout(function() {
    document.getElementById('cant-inp').focus();
    document.getElementById('add-form').scrollIntoView({behavior:'smooth',block:'nearest'});
  }, 100);
}

function cancelarAdd() {
  S.prodSeleccionado = null;
  S.motivoActual = null;
  document.getElementById('add-form').classList.remove('show');
  document.getElementById('cant-inp').value = '';
}

document.addEventListener('DOMContentLoaded', function() {
  // Limpiar caché viejo (strings simples sin unidades)
  try {
    var cached = localStorage.getItem('rdz_productos_cache');
    if (cached) {
      var d = JSON.parse(cached);
      var cat = d.productos && Object.keys(d.productos)[0];
      var item = cat && d.productos[cat] && d.productos[cat][0];
      if (item && typeof item === 'string') {
        localStorage.removeItem('rdz_productos_cache');
        localStorage.removeItem('rdz_productos');
      }
    }
  } catch(e) {}

  // Cargar lista de productos desde el Sheet al iniciar
  cargarProductosDesdeSheet();

  document.getElementById('cant-inp').addEventListener('input', function() {
    var val = parseFloat(this.value);
    var necesitaMotivo = S.tipo === 'merma' || S.tipo === 'pt';
    var motivoOk = !necesitaMotivo || S.motivoActual;
    document.getElementById('btn-agregar').disabled = !(val > 0 && motivoOk);
  });
});

function selMotivo(m) {
  S.motivoActual = m;
  var map = {'Vencimiento':'venc','Preparación':'prep','Accidente':'acc','Otro':'otro'};
  ['venc','prep','acc','otro'].forEach(function(id) {
    document.getElementById('m-'+id).className = 'mot-btn';
  });
  document.getElementById('m-'+map[m]).className = 'mot-btn sel';

  var val = parseFloat(document.getElementById('cant-inp').value);
  document.getElementById('btn-agregar').disabled = !(val > 0);
}

function confirmarAgregar() {
  var cant = parseFloat(document.getElementById('cant-inp').value);
  var uni  = document.getElementById('uni-sel').value;
  if (!cant || cant <= 0) return;

  // Chequear si ya está en la lista
  var yaExiste = S.items.findIndex(function(i) { return i.nombre === S.prodSeleccionado; });
  if (yaExiste >= 0) {
    // Sumar cantidad si ya existe
    S.items[yaExiste].cantidad += cant;
  } else {
    S.items.push({
      nombre: S.prodSeleccionado,
      cantidad: cant,
      unidad: uni,
      motivo: S.motivoActual || '-'
    });
  }

  document.getElementById('add-form').classList.remove('show');
  document.getElementById('cant-inp').value = '';
  document.getElementById('search-inp').value = '';
  renderLista('');
  renderItems();
  actualizarBoton();

  // Scroll al top de la lista de items
  setTimeout(function() {
    document.getElementById('items-wrap').scrollIntoView({behavior:'smooth',block:'nearest'});
  }, 50);
}

// ── RENDER ITEMS AGREGADOS ──────────────────────────────────────────────────
function renderItems() {
  var wrap = document.getElementById('items-wrap');
  var lista = document.getElementById('items-list');
  var countTxt = document.getElementById('items-count-txt');

  if (S.items.length === 0) {
    wrap.classList.add('hidden');
    return;
  }

  wrap.classList.remove('hidden');
  var n = S.items.length;
  countTxt.innerHTML = '<span>'+n+'</span> producto'+(n>1?'s':'')+' agregado'+(n>1?'s':'');

  lista.innerHTML = S.items.map(function(item, idx) {
    return '<div class="item-row">' +
      '<span class="item-nombre">'+item.nombre+'</span>' +
      '<span class="item-cant">'+item.cantidad+' '+item.unidad+'</span>' +
      '<button type="button" class="item-del" onclick="eliminarItem('+idx+')">×</button>' +
    '</div>';
  }).join('');
}

function eliminarItem(idx) {
  S.items.splice(idx, 1);
  renderItems();
  actualizarBoton();
}

// ── BOTÓN ENVIAR ───────────────────────────────────────────────────────────
function actualizarBoton() {
  var ok = S.tipo && S.items.length > 0;
  var btn = document.getElementById('btn-enviar');
  var badge = document.getElementById('btn-badge');
  var txt = document.getElementById('btn-txt');

  btn.disabled = !ok;

  if (S.items.length > 0) {
    badge.textContent = S.items.length;
    badge.classList.remove('hidden');
    txt.textContent = 'Registrar movimiento';
  } else {
    badge.classList.add('hidden');
    txt.textContent = 'Registrar movimiento';
  }
}

// ── ENVIAR ─────────────────────────────────────────────────────────────────
function enviar() {
  if (!S.tipo || S.items.length === 0) return;

  var btn = document.getElementById('btn-enviar');
  btn.disabled = true;
  document.getElementById('btn-txt').innerHTML = '';
  btn.querySelector('.badge') && btn.querySelector('.badge').classList.add('hidden');
  var spin = document.createElement('div');
  spin.className = 'spin';
  btn.prepend(spin);

  var tipoLabel = {
    consumo: 'Consumo producción',
    traslado: 'Traslado a Saavedra',
    merma: 'Merma / pérdida',
    pt: 'Prod. terminado perdido'
  }[S.tipo];

  var ahora = new Date();
  var payload = {
    fecha:    ahora.toLocaleDateString('es-AR'),
    hora:     ahora.toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'}),
    tipo:     tipoLabel,
    items:    S.items,
    obs:      document.getElementById('obs-inp').value || '-',
    timestamp: ahora.getTime()
  };

  if (SCRIPT_URL === 'REEMPLAZAR_CON_TU_URL_DE_APPS_SCRIPT') {
    setTimeout(function() { mostrarConfirmacion(payload); }, 700);
    return;
  }

  fetch(SCRIPT_URL, {
    method: 'POST',
    mode: 'no-cors',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(payload)
  })
  .then(function() { mostrarConfirmacion(payload); })
  .catch(function() {
    // Backup local
    try {
      var p = JSON.parse(localStorage.getItem('rdz_pendientes')||'[]');
      p.push(payload);
      localStorage.setItem('rdz_pendientes', JSON.stringify(p));
    } catch(e){}
    mostrarConfirmacion(payload);
  });
}

function mostrarConfirmacion(payload) {
  document.getElementById('form-screen').style.display = 'none';
  document.getElementById('btn-wrap').style.display = 'none';

  var itemsHtml = payload.items.map(function(i) {
    return '• ' + i.nombre + ' — ' + i.cantidad + ' ' + i.unidad;
  }).join('<br>');

  document.getElementById('confirm-detail').innerHTML =
    '<div class="cf-row"><span class="cf-lbl">Tipo</span><span class="cf-val">'+payload.tipo+'</span></div>' +
    '<div class="cf-row"><span class="cf-lbl">Productos</span><span class="cf-val cf-items">'+itemsHtml+'</span></div>' +
    '<div class="cf-row"><span class="cf-lbl">Hora</span><span class="cf-val">'+payload.fecha+' '+payload.hora+'</span></div>';

  document.getElementById('confirm').classList.add('show');
}

// ── RESET ──────────────────────────────────────────────────────────────────
function reset() {
  S = { tipo: null, items: [], prodSeleccionado: null, motivoActual: null };

  document.getElementById('confirm').classList.remove('show');
  document.getElementById('form-screen').style.display = '';
  document.getElementById('btn-wrap').style.display = '';

  ['consumo','traslado','merma','pt'].forEach(function(t) {
    document.getElementById('t-'+t).className = 'tipo-btn';
  });
  document.getElementById('card-productos').classList.add('hidden');
  document.getElementById('card-obs').classList.add('hidden');
  document.getElementById('items-wrap').classList.add('hidden');
  document.getElementById('items-list').innerHTML = '';
  document.getElementById('add-form').classList.remove('show');
  document.getElementById('search-inp').value = '';
  document.getElementById('obs-inp').value = '';

  var btn = document.getElementById('btn-enviar');
  btn.disabled = true;
  document.getElementById('btn-txt').textContent = 'Registrar movimiento';
  document.getElementById('btn-badge').classList.add('hidden');
  // Remover spinner si quedó
  var sp = btn.querySelector('.spin');
  if (sp) sp.remove();

  window.scrollTo(0,0);
}

// Init — renderLista se llama después de cargar productos
</script>
</body>
</html>
