<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Rodziny · Registro de Movimientos</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:      #0F1923;
    --sur:     #182230;
    --sur2:    #1F2E40;
    --bor:     rgba(255,255,255,0.08);
    --bor2:    rgba(255,255,255,0.14);
    --acc:     #3B82F6;
    --acc2:    #1D4ED8;
    --txt:     #F0F4F8;
    --mut:     #8CA0B8;
    --red:     #EF4444;
    --yel:     #F59E0B;
    --grn:     #22C55E;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--txt);
    min-height: 100vh;
    padding: 0 0 100px;
  }

  /* HEADER */
  .hdr {
    background: var(--sur);
    border-bottom: 1px solid var(--bor);
    padding: 14px 18px;
    position: sticky; top: 0; z-index: 20;
    display: flex; align-items: center; gap: 12px;
  }
  .hdr-logo {
    width: 34px; height: 34px; background: var(--acc);
    border-radius: 8px; display: flex; align-items: center; justify-content: center;
    font-family: 'DM Mono', monospace; font-size: 12px; color: #fff; font-weight: 500;
    flex-shrink: 0;
  }
  .hdr h1 { font-size: 14px; font-weight: 600; }
  .hdr p  { font-size: 11px; color: var(--mut); margin-top: 1px; }

  /* CARD */
  .card {
    margin: 14px 14px 0;
    background: var(--sur);
    border: 1px solid var(--bor);
    border-radius: 14px; overflow: hidden;
  }
  .card-hdr {
    padding: 12px 16px;
    border-bottom: 1px solid var(--bor);
    display: flex; align-items: center; gap: 10px;
  }
  .card-num {
    width: 24px; height: 24px; border-radius: 6px;
    background: var(--acc); color: #fff;
    font-size: 11px; font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .card-ttl { font-size: 13px; font-weight: 600; }
  .card-body { padding: 14px 16px; }

  /* TIPO */
  .tipo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .tipo-btn {
    background: var(--sur2); border: 1.5px solid var(--bor2);
    border-radius: 10px; padding: 12px 8px;
    cursor: pointer; text-align: center;
    transition: all 0.15s; touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }
  .tipo-btn .ico { font-size: 20px; display: block; margin-bottom: 5px; }
  .tipo-btn .lbl { font-size: 11px; font-weight: 500; color: var(--mut); line-height: 1.3; }
  .tipo-btn.sel-consumo  { background: rgba(59,130,246,.15); border-color: var(--acc); }
  .tipo-btn.sel-consumo  .lbl { color: #93C5FD; }
  .tipo-btn.sel-traslado { background: rgba(245,158,11,.15); border-color: var(--yel); }
  .tipo-btn.sel-traslado .lbl { color: #FCD34D; }
  .tipo-btn.sel-merma    { background: rgba(239,68,68,.15);  border-color: var(--red); }
  .tipo-btn.sel-merma    .lbl { color: #FCA5A5; }
  .tipo-btn.sel-pt       { background: rgba(168,85,247,.15); border-color: #A855F7; }
  .tipo-btn.sel-pt       .lbl { color: #D8B4FE; }

  /* BUSCADOR */
  .search-wrap { position: relative; }
  .search-ico {
    position: absolute; left: 12px; top: 50%;
    transform: translateY(-50%);
    color: var(--mut); font-size: 14px; pointer-events: none;
  }
  .search-inp {
    width: 100%;
    background: var(--sur2); border: 1.5px solid var(--bor2);
    border-radius: 10px; padding: 11px 14px 11px 36px;
    font-family: 'DM Sans', sans-serif; font-size: 14px;
    color: var(--txt); outline: none;
  }
  .search-inp:focus { border-color: var(--acc); }
  .search-inp::placeholder { color: var(--mut); }

  .cat-lbl {
    font-size: 10px; font-weight: 600; color: var(--mut);
    text-transform: uppercase; letter-spacing: .8px;
    padding: 10px 2px 4px;
  }
  .prod-list {
    max-height: 200px; overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    margin-top: 8px;
  }
  .prod-btn {
    width: 100%; background: transparent; border: none;
    padding: 9px 10px; border-radius: 8px;
    cursor: pointer; font-size: 13px; color: var(--txt);
    text-align: left; font-family: 'DM Sans', sans-serif;
    display: flex; align-items: center; justify-content: space-between;
    touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    transition: background .1s;
  }
  .prod-btn:hover, .prod-btn:active { background: var(--sur2); }

  /* AGREGAR PRODUCTO — mini form inline */
  .add-form {
    display: none;
    background: rgba(59,130,246,.08);
    border: 1px solid rgba(59,130,246,.25);
    border-radius: 10px; padding: 12px; margin-top: 10px;
  }
  .add-form.show { display: block; }
  .add-prod-nombre {
    font-size: 13px; font-weight: 600; color: #93C5FD;
    margin-bottom: 10px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .add-prod-nombre button {
    background: none; border: none; color: var(--mut);
    font-size: 16px; cursor: pointer; padding: 0 4px;
    line-height: 1; touch-action: manipulation;
  }
  .cant-row { display: flex; gap: 8px; align-items: stretch; }
  .cant-inp {
    flex: 1; background: var(--sur2); border: 1.5px solid var(--bor2);
    border-radius: 8px; padding: 10px 12px;
    font-family: 'DM Mono', monospace; font-size: 18px; font-weight: 500;
    color: var(--txt); text-align: center; outline: none;
  }
  .cant-inp:focus { border-color: var(--acc); }
  .uni-sel {
    background: var(--sur2); border: 1.5px solid var(--bor2);
    border-radius: 8px; padding: 10px 10px;
    font-family: 'DM Sans', sans-serif; font-size: 13px;
    color: var(--txt); outline: none; min-width: 68px;
  }
  .btn-agregar {
    width: 100%; margin-top: 10px; padding: 10px;
    background: var(--acc); border: none; border-radius: 8px;
    font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600;
    color: #fff; cursor: pointer; touch-action: manipulation;
  }
  .btn-agregar:active { background: var(--acc2); }
  .btn-agregar:disabled { opacity: .5; cursor: not-allowed; }

  /* MOTIVO */
  .motivo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-top: 10px; }
  .mot-btn {
    background: var(--sur2); border: 1.5px solid var(--bor2);
    border-radius: 8px; padding: 8px;
    cursor: pointer; font-size: 12px; color: var(--mut);
    text-align: center; font-family: 'DM Sans', sans-serif;
    touch-action: manipulation;
  }
  .mot-btn.sel { background: rgba(239,68,68,.15); border-color: var(--red); color: #FCA5A5; }

  /* LISTA DE PRODUCTOS AGREGADOS */
  .items-list { display: flex; flex-direction: column; gap: 6px; }
  .item-row {
    display: flex; align-items: center; gap: 10px;
    background: var(--sur2); border-radius: 8px;
    padding: 9px 12px; animation: slideIn .15s ease;
  }
  @keyframes slideIn { from { opacity:0; transform:translateY(-4px); } to { opacity:1; transform:none; } }
  .item-nombre { flex: 1; font-size: 13px; color: var(--txt); }
  .item-cant {
    font-family: 'DM Mono', monospace; font-size: 13px;
    color: #93C5FD; font-weight: 500; white-space: nowrap;
  }
  .item-del {
    background: none; border: none; color: var(--mut);
    font-size: 16px; cursor: pointer; padding: 0 2px;
    line-height: 1; touch-action: manipulation;
    flex-shrink: 0;
  }
  .item-del:hover { color: var(--red); }

  .items-count {
    font-size: 11px; color: var(--mut);
    padding: 4px 0 10px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .items-count span { color: #93C5FD; font-weight: 600; }

  /* OBSERVACION */
  .obs-inp {
    width: 100%; background: var(--sur2);
    border: 1.5px solid var(--bor2); border-radius: 10px;
    padding: 11px 14px; font-family: 'DM Sans', sans-serif;
    font-size: 13px; color: var(--txt); outline: none;
    resize: none; min-height: 65px;
  }
  .obs-inp:focus { border-color: var(--acc); }
  .obs-inp::placeholder { color: var(--mut); }

  /* BTN ENVIAR */
  .btn-wrap {
    position: fixed; bottom: 0; left: 0; right: 0;
    padding: 12px 16px 28px;
    background: linear-gradient(to top, var(--bg) 65%, transparent);
    z-index: 10;
  }
  .btn-enviar {
    width: 100%; padding: 15px;
    background: var(--acc); border: none; border-radius: 12px;
    font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 600;
    color: #fff; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    touch-action: manipulation;
  }
  .btn-enviar:active  { background: var(--acc2); transform: scale(.98); }
  .btn-enviar:disabled { opacity: .5; cursor: not-allowed; }
  .badge {
    background: rgba(255,255,255,.25);
    border-radius: 20px; padding: 2px 8px;
    font-size: 12px; font-weight: 700;
  }

  /* CONFIRMACIÓN */
  .confirm {
    display: none; flex-direction: column;
    align-items: center; justify-content: center;
    min-height: 75vh; padding: 40px 20px; text-align: center;
  }
  .confirm.show { display: flex; }
  .confirm-ico {
    width: 70px; height: 70px;
    background: rgba(34,197,94,.15); border: 2px solid rgba(34,197,94,.4);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 30px; margin-bottom: 18px;
    animation: pop .3s cubic-bezier(.34,1.56,.64,1);
  }
  @keyframes pop { from { transform:scale(0); } to { transform:scale(1); } }
  .confirm h2 { font-size: 20px; font-weight: 600; margin-bottom: 6px; }
  .confirm p  { font-size: 13px; color: var(--mut); line-height: 1.6; margin-bottom: 24px; }
  .confirm-card {
    background: var(--sur); border: 1px solid var(--bor);
    border-radius: 12px; padding: 14px 18px;
    width: 100%; max-width: 320px;
    text-align: left; margin-bottom: 22px;
  }
  .cf-row {
    display: flex; justify-content: space-between; align-items: flex-start;
    padding: 6px 0; font-size: 13px; gap: 12px;
  }
  .cf-row:not(:last-child) { border-bottom: 1px solid var(--bor); }
  .cf-lbl { color: var(--mut); flex-shrink: 0; }
  .cf-val { font-weight: 500; text-align: right; }
  .cf-items { font-size: 12px; color: var(--txt); line-height: 1.8; }
  .btn-nuevo {
    background: transparent; border: 1.5px solid var(--bor2);
    border-radius: 10px; padding: 13px 28px;
    font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500;
    color: var(--txt); cursor: pointer; touch-action: manipulation;
  }

  .hidden  { display: none !important; }
  .spin {
    width: 18px; height: 18px;
    border: 2px solid rgba(255,255,255,.3);
    border-top-color: #fff; border-radius: 50%;
    animation: spin .6s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-thumb { background: var(--bor2); border-radius: 2px; }
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-logo">Rdz</div>
  <div>
    <h1>Registro de Movimientos</h1>
    <p>Depósito Saavedra · <span id="hora"></span></p>
  </div>
</div>

<div id="form-screen">

  <!-- PASO 1: TIPO -->
  <div class="card">
    <div class="card-hdr">
      <div class="card-num">1</div>
      <div class="card-ttl">¿Qué tipo de movimiento?</div>
    </div>
    <div class="card-body">
      <div class="tipo-grid">
        <button class="tipo-btn" onclick="selTipo('consumo')" id="t-consumo">
          <span class="ico">🍳</span><span class="lbl">Consumo en producción</span>
        </button>
        <button class="tipo-btn" onclick="selTipo('traslado')" id="t-traslado">
          <span class="ico">🚚</span><span class="lbl">Traslado a Saavedra</span>
        </button>
        <button class="tipo-btn" onclick="selTipo('merma')" id="t-merma">
          <span class="ico">⚠️</span><span class="lbl">Merma / pérdida / vencimiento</span>
        </button>
        <button class="tipo-btn" onclick="selTipo('pt')" id="t-pt">
          <span class="ico">📦</span><span class="lbl">Producto terminado echado a perder</span>
        </button>
      </div>
    </div>
  </div>

  <!-- PASO 2: AGREGAR PRODUCTOS -->
  <div class="card hidden" id="card-productos">
    <div class="card-hdr">
      <div class="card-num">2</div>
      <div class="card-ttl" id="ttl-productos">¿Qué productos?</div>
    </div>
    <div class="card-body">

      <!-- Lista de items ya agregados -->
      <div id="items-wrap" class="hidden">
        <div class="items-count">
          <span id="items-count-txt">0 productos agregados</span>
          <span style="color:var(--mut);font-size:11px">Podés seguir agregando</span>
        </div>
        <div class="items-list" id="items-list"></div>
        <div style="height:10px"></div>
      </div>

      <!-- Indicador de carga -->
      <div id="loading-productos" style="display:none;font-size:11px;color:var(--mut);text-align:center;padding:8px">
        Cargando lista de productos...
      </div>

      <!-- Buscador -->
      <div class="search-wrap">
        <span class="search-ico">🔍</span>
        <input class="search-inp" type="text" id="search-inp"
               placeholder="Buscar producto..." autocomplete="off"
               oninput="filtrar(this.value)">
      </div>
      <div class="prod-list" id="prod-list"></div>

      <!-- Mini form para agregar cantidad -->
      <div class="add-form" id="add-form">
        <div class="add-prod-nombre">
          <span id="add-nombre">—</span>
          <button onclick="cancelarAdd()" type="button">✕</button>
        </div>

        <!-- Motivo (solo merma/pt) -->
        <div id="motivo-wrap" class="hidden">
          <div style="font-size:11px;color:var(--mut);margin-bottom:4px">Motivo</div>
          <div class="motivo-grid">
            <button type="button" class="mot-btn" onclick="selMotivo('Vencimiento')" id="m-venc">📅 Vencimiento</button>
            <button type="button" class="mot-btn" onclick="selMotivo('Preparación')" id="m-prep">🍽️ Preparación</button>
            <button type="button" class="mot-btn" onclick="selMotivo('Accidente')" id="m-acc">💥 Accidente</button>
            <button type="button" class="mot-btn" onclick="selMotivo('Otro')" id="m-otro">❓ Otro</button>
          </div>
        </div>

        <div class="cant-row" style="margin-top:10px">
          <input class="cant-inp" type="number" id="cant-inp"
                 placeholder="0" min="0.01" step="0.01" inputmode="decimal">
          <select class="uni-sel" id="uni-sel">
            <option value="kg">kg</option>
            <option value="u.">u.</option>
            <option value="unid.">unid.</option>
            <option value="L">L</option>
            <option value="gr">gr</option>
            <option value="ml">ml</option>
            <option value="porc.">porc.</option>
          </select>
        </div>
        <button class="btn-agregar" id="btn-agregar"
                onclick="confirmarAgregar()" disabled>
          + Agregar a la lista
        </button>
      </div>

    </div>
  </div>

  <!-- PASO 3: OBSERVACIÓN -->
  <div class="card hidden" id="card-obs">
    <div class="card-hdr">
      <div class="card-num">3</div>
      <div class="card-ttl">
        Observación
        <span style="color:var(--mut);font-weight:400;font-size:11px"> — opcional</span>
      </div>
    </div>
    <div class="card-body">
      <textarea class="obs-inp" id="obs-inp"
                placeholder="Ej: pedido de la barra, producto vencido lote X, etc."></textarea>
    </div>
  </div>

  <div style="height:16px"></div>
</div>

<!-- CONFIRMACIÓN -->
<div class="confirm" id="confirm">
  <div class="confirm-ico">✓</div>
  <h2>Movimiento registrado</h2>
  <p>Se guardó correctamente<br>en la planilla de Rodziny.</p>
  <div class="confirm-card" id="confirm-detail"></div>
  <button class="btn-nuevo" onclick="reset()">+ Registrar otro movimiento</button>
</div>

<!-- BOTÓN ENVIAR -->
<div class="btn-wrap" id="btn-wrap">
  <button class="btn-enviar" id="btn-enviar" onclick="enviar()" disabled>
    <span id="btn-txt">Registrar movimiento</span>
    <span class="badge hidden" id="btn-badge">0</span>
  </button>
</div>

<script>
// ── PRODUCTOS ──────────────────────────────────────────────────────────────
// ── URL DEL APPS SCRIPT (scope global para que todas las funciones lo usen) ──
var SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbw91Jdn9ogxJqlTQs7nuYDjTna0tUK8E6UOmy04mD8pgN-8dMSuXq0v7Av9XSsZLyW2/exec';

// ── PRODUCTOS — se cargan dinámicamente desde el Sheet ──────────────────────
var MP = {}; // Se llena al cargar la página
var MP_CARGADO = false;
var FORM_VERSION = 'sg1'; // Incrementar cuando cambie la estructura de datos del caché

function cargarProductosDesdeSheet() {
  var statusEl = document.getElementById('loading-productos');

  // 1. Verificar caché válido con objetos {n,u}
  try {
    var cached = localStorage.getItem('rdz_productos_cache');
    if (cached) {
      var cacheData = JSON.parse(cached);
      if (cacheData && cacheData.form_version === FORM_VERSION &&
          cacheData.productos && Object.keys(cacheData.productos).length > 0) {
        var primeraCat = Object.keys(cacheData.productos)[0];
        var primerItem = cacheData.productos[primeraCat] && cacheData.productos[primeraCat][0];
        if (primerItem && typeof primerItem === 'object' && primerItem.u) {
          MP = cacheData.productos;
          MP_CARGADO = true;
          if (statusEl) statusEl.style.display = 'none';
          if (S.tipo && S.tipo !== 'pt') renderLista('');
        } else {
          localStorage.removeItem('rdz_productos_cache');
        }
      } else {
        localStorage.removeItem('rdz_productos_cache');
        localStorage.removeItem('rdz_productos');
      }
    }
  } catch(e) {
    localStorage.removeItem('rdz_productos_cache');
    localStorage.removeItem('rdz_productos');
  }

  // 2. Cargar desde Sheet — siempre, para actualizar caché
  if (!MP_CARGADO && statusEl) statusEl.style.display = 'block';

  var controller = new AbortController();
  var timeout = setTimeout(function() {
    controller.abort();
    if (!MP_CARGADO) {
      MP = MP_FALLBACK; MP_CARGADO = true;
      if (statusEl) statusEl.style.display = 'none';
      if (S.tipo && S.tipo !== 'pt') renderLista('');
    }
  }, 8000);

  fetch(SCRIPT_URL + '?accion=productos', { signal: controller.signal })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      clearTimeout(timeout);
      if (data.ok && data.data && Object.keys(data.data).length > 0) {
        var cat0 = Object.keys(data.data)[0];
        var item0 = data.data[cat0] && data.data[cat0][0];
        var tieneU = item0 && typeof item0 === 'object' && item0.u;
        if (tieneU) {
          MP = data.data; MP_CARGADO = true;
          try {
            localStorage.setItem('rdz_productos_cache', JSON.stringify({
              productos: data.data, version: data.version || Date.now(),
              form_version: FORM_VERSION, fecha: new Date().toISOString()
            }));
            localStorage.removeItem('rdz_productos');
          } catch(e){}
          if (statusEl) statusEl.style.display = 'none';
          if (S.tipo && S.tipo !== 'pt') renderLista(document.getElementById('search-inp').value || '');
        } else if (!MP_CARGADO) {
          MP = MP_FALLBACK; MP_CARGADO = true;
          if (statusEl) statusEl.style.display = 'none';
          if (S.tipo && S.tipo !== 'pt') renderLista('');
        }
      } else if (!MP_CARGADO) {
        MP = MP_FALLBACK; MP_CARGADO = true;
        if (statusEl) statusEl.style.display = 'none';
        if (S.tipo && S.tipo !== 'pt') renderLista('');
      }
    })
    .catch(function() {
      clearTimeout(timeout);
      if (!MP_CARGADO) {
        MP = MP_FALLBACK; MP_CARGADO = true;
        if (statusEl) statusEl.style.display = 'none';
        if (S.tipo && S.tipo !== 'pt') renderLista('');
      }
    });
}
var MP_FALLBACK = {
  "Vicctorello": [
    {
      "n": "Aceite de Girasol",
      "u": "L"
    },
    {
      "n": "Crema de Leche",
      "u": "kg"
    },
    {
      "n": "Leche Sachet x 1 L",
      "u": "L"
    },
    {
      "n": "Leche descremada en polvo",
      "u": "kg"
    },
    {
      "n": "Leche entera en polvo",
      "u": "kg"
    },
    {
      "n": "Manteca",
      "u": "kg"
    },
    {
      "n": "Queso Cheddar",
      "u": "kg"
    },
    {
      "n": "Queso Danbo",
      "u": "kg"
    },
    {
      "n": "Queso Muzzarella",
      "u": "kg"
    },
    {
      "n": "Queso Parmesano",
      "u": "kg"
    },
    {
      "n": "Queso Pategras",
      "u": "kg"
    },
    {
      "n": "Queso Provoleta",
      "u": "kg"
    },
    {
      "n": "Queso Provolone",
      "u": "kg"
    },
